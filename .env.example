# =============================================================================
# Hoopify — copy to .env and fill in (never commit .env)
# =============================================================================

# --- Stripe (https://dashboard.stripe.com/apikeys) ---
# Use sk_test_ / pk_test_ for development; sk_live_ / pk_live_ for production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_

# Webhook signing secret (see webhook section below). Starts with whsec_
STRIPE_WEBHOOK_SECRET=whsec_...

# Public site URL with NO trailing slash. Used for Checkout success/cancel redirects.
# Local:  http://localhost:8085
# Render: https://your-service.onrender.com
PUBLIC_BASE_URL=http://localhost:8085

# Port (optional locally). Render injects PORT automatically — do not set on Render unless needed.
# PORT=8085
